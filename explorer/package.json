{
  "name": "swamp-explorer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:server": "tsc -p server/tsconfig.json",
    "build:web": "vite build",
    "build": "npm run build:server && npm run build:web",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite",
    "dev": "concurrently -n server,web -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "dev:remote": "HOST=0.0.0.0 concurrently -n server,web -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -p server/tsconfig.json --noEmit && tsc -p web/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@xyflow/react": "^12.3.5",
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}